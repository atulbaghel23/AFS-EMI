{
  "name": "emi-fullstack",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "server": "nodemon backend/server.js",
    "build": "vercel build",
    "postinstall": "cd frontend && npm install",
    "start": "cross-env NODE_ENV=production node backend/server.js",
    "client": "npm --prefix frontend run dev",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "seed": "node seed.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "file-saver": "^2.0.5",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.6.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "pdf-parse": "^2.4.5",
    "pptxgenjs": "^4.0.1",
    "puppeteer": "^24.43.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.14"
  }
}